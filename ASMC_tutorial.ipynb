    "# Definition of Potential\n",
    "def V_higher(x):\n",
    "    x1, x2, x3 = tf.split(x, 3, axis=1)\n",
    "    return (x1**3 + x2**2 * x3 + x2 * x3**2 -1)**2\n",
    "\n",
    "# Randomly initialize the points\n",
    "n_points = 20_000\n",
    "np.random.seed = 42\n",
    "x_3d = tf.Variable(4*np.random.rand(n_points, 3)-2, dtype=tf.float32)\n",
    "\n",
    "# Find vacua (need more iterations for higher-dim example)\n",
    "n_steps = 10_000\n",
    "alpha = 1e-3\n",
    "resets = {\n",
    "    2000: 1,\n",
    "    4000: 1,\n",
    "    6000: 1,\n",
    "    8000: 10,\n",
    "    9000: 10,\n",
    "    9500: 10\n",
    "}\n",
    "tolerance = -8\n",
    "\n",
    "history_loss_3d, history_rate_3d = vacuum_finder(\n",
    "    V=V_higher, \n",
    "    x=x_3d, \n",
    "    n_steps=n_steps, \n",
    "    alpha=alpha,\n",
    "    tol=tolerance,\n",
    "    resets=resets,\n",
    "    verbose=True\n",
    ")"
   ]
  },
