   "source": [
    "# ASMC optimization\n",
    "all_out = sampler_circle.run_annealing_is(\n",
    "    n_iter=500,       \n",
    "    n_particles=1000,  \n",
    "    verbose=True,\n",
    "    adaptative_temp=True,\n",
    "    degree_bias=0.,\n",
    "    sparsity_factor=0.,\n",
    "    adaptation_strength=lambda i,n_iter : 0.05,\n",
    "    target_acc_rate = lambda x,y : 0.8 - 0.5 * x/y,\n",
    "    beta_schedule=lambda i,n_iter: 1e-10\n",
    ")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e52345b7-e03b-48d1-9dc5-4145a01d8bbc",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Local search around best ASMC solution\n",
    "best_coeffs = all_out[0]\n",
    "bc_trunc = sampler_circle.apply_coefficient_threshold(best_coeffs)\n",
    "res, loss = sampler_circle.local_search(best_coeffs,n_steps=1000,use_reg=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "6b3f98af-e2ea-419c-a88f-9d3ed7ad0013",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle x_{1}^{2} \\left(- x_{1}^{2} - x_{2}^{2} + 1\\right)$"
      ],
      "text/plain": [
       "x1**2*(-x1**2 - x2**2 + 1)"
      ]
     },
     "execution_count": 16,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Normalisation\n",
    "sampler_circle.min_coeff_threshold = 1e-3\n",
    "res_trunc = sampler_circle.apply_coefficient_threshold(res)\n",
    "nonzero_indices = np.nonzero(res_trunc)\n",
    "coeff_min = np.min(abs(res_trunc[nonzero_indices]))\n",
    "\n",
    "# Final reconstruction\n",
    "sympy.simplify(sampler_circle.polynomial_to_string(res/coeff_min, 1e-3))"
   ]
  },
